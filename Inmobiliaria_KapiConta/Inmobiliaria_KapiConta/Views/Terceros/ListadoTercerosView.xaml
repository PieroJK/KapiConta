<UserControl x:Class="Inmobiliaria_KapiConta.Views.Terceros.ListadoTercerosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Inmobiliaria_KapiConta.Views.Terceros"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Padding="14,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Width="1108"
            Height="598"
            Background="#31465B"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Padding="22" Margin="21,0,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <!-- IZQUIERDA -->
                <Grid Grid.Column="0" Margin="0,0,20,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Listado Terceros"
                           Foreground="White"
                           FontSize="42"
                           FontWeight="SemiBold"/>

                    <!-- FILTRO -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                               Text="Filtro"
                               Style="{StaticResource LabelStyle}"/>

                        <ComboBox 
                              Grid.Column="1"
                              Height="34"
                              FontSize="16"
                              Background="#D9D9D9"
                              SelectedValue="{Binding Filtro}"
                              SelectedValuePath="Content"
                              SelectedIndex="0">
                            <ComboBoxItem Content="Razón Social"/>
                            <ComboBoxItem Content="Documento"/>
                            <ComboBoxItem Content="Dirección"/>
                        </ComboBox>

                        <TextBox 
                             Grid.Column="3"
                             Height="34"
                             FontSize="16"
                             Background="#D9D9D9"
                             Text="{Binding TextoBuscar, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid 
                  Background="#80000000"
                  Visibility="{Binding OverlayVisible}"
                  Panel.ZIndex="100">
                        <Border Width="1132"
                        Height="598"
                        Background="#31465B"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                            <ContentControl Content="{Binding VistaActual}"/>
                        </Border>
                    </Grid>

                    <!-- TABLA -->
                    <DataGrid 
                          Grid.Row="4"
                          Margin="14,0,0,0"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          RowHeaderWidth="0"
                          Background="#E7E7E7"
                          BorderBrush="Black"
                          BorderThickness="2"
                          FontSize="14"
                          ItemsSource="{Binding Terceros}"
                          SelectedItem="{Binding TerceroSeleccionado}"
                          MouseDoubleClick="dgTerceros_MouseDoubleClick">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código"
                                            Binding="{Binding Documento}"
                                            Width="150"/>

                            <DataGridTextColumn Header="Razón Social / Nombre"
                                            Binding="{Binding RazonSocial}"
                                            Width="290"/>

                            <DataGridTextColumn Header="Dirección"
                                            Binding="{Binding Direccion}"
                                            Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- DERECHA -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Background="#1A1A1A"
                        BorderThickness="1"
                        BorderBrush="#203040">
                        <Grid>
                            <Image Source="/Assets/logo.png"/>
                        </Grid>
                    </Border>

                    <Button 
                        Grid.Row="2"
                        Content="Ingresar"
                        Background="#4B5FD6"
                        Style="{StaticResource RoundedButtonStyle}"
                        Command="{Binding IngresarCommand}"/>

                    <Button 
                        Grid.Row="4"
                        Content="Exportar"
                        Background="#F46A1F"
                        Style="{StaticResource RoundedButtonStyle}"
                        Command="{Binding ExportarCommand}"/>

                    <Button 
                        Grid.Row="6"
                        Content="Volver"
                        Background="#D9412C"
                        Style="{StaticResource RoundedButtonStyle}"
                        Command="{Binding VolverCommand}"/>

                    <StackPanel Grid.Row="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Image Source="/Assets/CAPIBARA.png"
                           Width="72"
                           Height="42"
                           Stretch="Uniform"/>
                        <TextBlock Text="KapiConta"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
