<Window x:Class="Inmobiliaria_KapiConta.Views.Terceros.EditarTerceroView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inmobiliaria_KapiConta.Views.Terceros"
        mc:Ignorable="d"
        Title="EditarTerceroView" Height="450" Width="948">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="18"
                        Padding="14,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Width="945"
         Height="470"
         Background="#31465B"
         HorizontalAlignment="Center"
         VerticalAlignment="Center"
         Padding="22">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="155"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Text="Modificar Tercero"
                        Foreground="White"
                        FontSize="44"
                        FontWeight="SemiBold"
                        Margin="0,0,0,2"/>

                    <TextBlock x:Name="lblDocumento"
                        Grid.Row="2"
                        Grid.Column="0"
                        Text="Documento"
                        Foreground="White"
                        FontSize="17"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"/>

                    <TextBox 
                      Text="{Binding Documento}"
                      Grid.Row="2"
                      Grid.Column="1"
                      Grid.ColumnSpan="2"
                      Width="245"
                      HorizontalAlignment="Left"
                      Height="34"
                      FontSize="16"
                      Background="#D9D9D9"
                      BorderBrush="#23384D"
                      BorderThickness="1"
                      VerticalContentAlignment="Center"
                      Padding="8,0"
                      IsReadOnly="True"/>

                    <TextBlock Grid.Row="4"
                        Grid.Column="0"
                        Text="Razon"
                        Foreground="White"
                        FontSize="17"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"/>

                    <TextBox 
                      Text="{Binding RazonSocial, UpdateSourceTrigger=PropertyChanged}"
                      Grid.Row="4"
                      Grid.Column="1"
                      Grid.ColumnSpan="2"
                      Height="34"
                      FontSize="16"
                      Background="#D9D9D9"
                      BorderBrush="#23384D"
                      BorderThickness="1"
                      VerticalContentAlignment="Center"
                      Padding="8,0"/>

                    <TextBlock Grid.Row="6"
                        Grid.Column="0"
                        Text="Direccion"
                        Foreground="White"
                        FontSize="17"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,6,12,0"/>

                    <TextBox 
                      Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}"
                      Grid.Row="6"
                      Grid.Column="1"
                      Grid.ColumnSpan="2"
                      Height="82"
                      FontSize="16"
                      Background="#D9D9D9"
                      BorderBrush="#23384D"
                      BorderThickness="1"
                      Padding="8,6"
                      TextWrapping="Wrap"
                      AcceptsReturn="True"
                      VerticalContentAlignment="Top"/>

                    <TextBlock Grid.Row="8"
                        Grid.Column="0"
                        Text="Tipo Doc. Id"
                        Foreground="White"
                        FontSize="17"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"/>

                    <ComboBox 
                       Grid.Row="8"
                       Grid.Column="1"
                       Width="92"
                       HorizontalAlignment="Left"
                       Height="34"
                       FontSize="16"
                       Background="#D9D9D9"
                       BorderBrush="#23384D"
                       BorderThickness="1"
                       DisplayMemberPath="Cod"
                       ItemsSource="{Binding TiposDocumento}"
                       SelectedItem="{Binding TipoSeleccionado}"
                       />

                    <TextBox 
                      Grid.Row="8"
                      Grid.Column="2"
                      Margin="12,0,0,0"
                      Height="34"
                      FontSize="16"
                      Background="#D9D9D9"
                      BorderBrush="#23384D"
                      BorderThickness="1"
                      VerticalContentAlignment="Center"
                      Padding="8,0"
                      Text="{Binding NombreTipoDocumento}"
                      IsReadOnly="True"/>

                    <TextBlock Grid.Row="10"
                        Grid.Column="0"
                        Text="Condicion"
                        Foreground="White"
                        FontSize="17"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"/>

                    <ComboBox 
                       SelectedValue="{Binding Condicion}"
                       SelectedValuePath="Content"
                       Grid.Row="10"
                       Grid.Column="1"
                       Width="180"
                       HorizontalAlignment="Left"
                       Height="34"
                       FontSize="16"
                       Background="#D9D9D9"
                       BorderBrush="#23384D"
                       BorderThickness="1">
                        <ComboBoxItem Content="HABIDO"/>
                        <ComboBoxItem Content="NO HABIDO"/>
                    </ComboBox>

                    <TextBlock Grid.Row="10"
                        Grid.Column="2"
                        Text="Estado"
                        Foreground="White"
                        FontSize="17"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="24,0,0,0"/>

                    <TextBox 
                      Grid.Row="10"
                      Grid.Column="2"
                      Width="180"
                      HorizontalAlignment="Right"
                      Height="34"
                      FontSize="16"
                      Background="#D9D9D9"
                      BorderBrush="#23384D"
                      BorderThickness="1"
                      VerticalContentAlignment="Center"
                      Padding="8,0"
                      Text="{Binding Estado, Mode=OneWay}"
                      IsReadOnly="True"/>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                     Background="#1A1A1A"
                     BorderThickness="1"
                     BorderBrush="#203040">
                        <Grid>
                            <Image Source="/Assets/logo.png"/>
                        </Grid>
                    </Border>

                    <Button 
                     Grid.Row="2"
                     Content="Modificar"
                     Background="#F1C40F"
                     Style="{StaticResource RoundedButtonStyle}"
                     Command="{Binding GuardarCommand}"/>

                    <Button 
                     Grid.Row="4"
                     Content="Volver"
                     Background="#D9412C"
                     Style="{StaticResource RoundedButtonStyle}"
                     Command="{Binding CerrarCommand}" />

                    <Button 
                     Grid.Row="8"
                     Background="#4B5FD6"
                     Style="{StaticResource SideButtonStyle}"
                     >
                        <StackPanel Orientation="Horizontal"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                            <Image Source="/Assets/SUNAT.png"
                            Width="22"
                            Height="22"
                            Margin="0,0,8,0"
                            Stretch="Uniform"/>
                            <TextBlock Text="Sunat"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnDni"
                     Grid.Row="10"
                     Background="#4B5FD6"
                     Style="{StaticResource SideButtonStyle}"
                     >
                        <StackPanel Orientation="Horizontal"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                            <Image Source="/Assets/PERSONA.png"
                            Width="22"
                            Height="22"
                            Margin="0,0,8,0"
                            Stretch="Uniform"/>
                            <TextBlock Text="D.N.I"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
