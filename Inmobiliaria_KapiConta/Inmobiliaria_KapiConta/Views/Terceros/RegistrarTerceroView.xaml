<UserControl x:Class="Inmobiliaria_KapiConta.Views.Terceros.RegistrarTerceroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             Background="#2F4A5A">

    <UserControl.Resources>

        <!-- LABEL -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#D9D9D9"/>
            <Setter Property="BorderBrush" Value="#23384D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- COMBOBOX -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#D9D9D9"/>
        </Style>

        <!-- BOTON GRANDE -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- BOTON LATERAL -->
        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Border Width="910"
                Height="470"
                Background="#31465B"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="22">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="155"/>
                </Grid.ColumnDefinitions>

                <!-- IZQUIERDA -->
                <Grid Grid.Column="0" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TITULO -->
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="3"
                               Text="Registro de Terceros"
                               Foreground="White"
                               FontSize="44"
                               FontWeight="SemiBold"
                               Margin="0,0,0,2"/>

                    <!-- DOCUMENTO -->
                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="{Binding LabelDocumento}"
                               Style="{StaticResource LabelStyle}"/>

                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             Width="245"
                             HorizontalAlignment="Left"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- RAZON -->
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Razon"
                               Style="{StaticResource LabelStyle}"/>

                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding RazonSocial}"/>

                    <!-- DIRECCION -->
                    <TextBlock Grid.Row="6"
                               Grid.Column="0"
                               Text="Direccion"
                               Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Top"
                               Margin="0,6,12,0"/>

                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Grid.ColumnSpan="2"
                             Height="82"
                             FontSize="16"
                             Background="#D9D9D9"
                             BorderBrush="#23384D"
                             BorderThickness="1"
                             Padding="8,6"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Text="{Binding Direccion}"/>

                    <!-- TIPO DOC -->
                    <TextBlock Grid.Row="8"
                               Grid.Column="0"
                               Text="Tipo Doc. Id"
                               Style="{StaticResource LabelStyle}"/>

                    <ComboBox Grid.Row="8"
                              Grid.Column="1"
                              Width="92"
                              ItemsSource="{Binding TiposDocumento}"
                              SelectedItem="{Binding TipoSeleccionado}"
                              DisplayMemberPath="Cod"
                              Style="{StaticResource ComboStyle}"/>

                    <TextBox Grid.Row="8"
                             Grid.Column="2"
                             Margin="12,0,0,0"
                             Style="{StaticResource InputTextBoxStyle}"
                             IsReadOnly="True"
                             Background="#D9D9D9"
                             Text="{Binding NombreTipoDocumento}"/>

                    <!-- CONDICION -->
                    <TextBlock Grid.Row="10"
                               Grid.Column="0"
                               Text="Condicion"
                               Style="{StaticResource LabelStyle}"/>

                    <ComboBox Grid.Row="10"
                              Grid.Column="1"
                              Width="180"
                              SelectedValue="{Binding Condicion}"
                              SelectedValuePath="Content"
                              Style="{StaticResource ComboStyle}">
                        <ComboBoxItem Content="HABIDO"/>
                        <ComboBoxItem Content="NO HABIDO"/>
                    </ComboBox>

                    <!-- ESTADO -->
                    <TextBlock Grid.Row="10"
                               Grid.Column="2"
                               Text="Estado"
                               Foreground="White"
                               FontSize="17"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="24,0,0,0"/>

                    <TextBox Grid.Row="10"
                             Grid.Column="2"
                             Width="180"
                             HorizontalAlignment="Right"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding Estado, Mode=OneWay}"
                             IsReadOnly="True"/>
                </Grid>

                <!-- DERECHA -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>

                    <!-- LOGO -->
                    <Border Grid.Row="0"
                            Background="#1A1A1A"
                            BorderThickness="1"
                            BorderBrush="#203040">
                        <Grid>
                            <Image Source="/Assets/logo.png"/>
                        </Grid>
                    </Border>

                    <!-- BOTONES -->
                    <Button Grid.Row="2"
                            Content="Registrar"
                            Background="#25C35A"
                            Style="{StaticResource RoundedButtonStyle}"
                            Command="{Binding RegistrarCommand}"/>

                    <Button Grid.Row="4"
                            Content="Volver"
                            Background="#D9412C"
                            Style="{StaticResource RoundedButtonStyle}"
                            Command="{Binding VolverCommand}"/>

                    <Button Grid.Row="6"
                            Content="Importar"
                            Background="#F46A1F"
                            Style="{StaticResource RoundedButtonStyle}"
                            Command="{Binding ImportarCommand}"/>

                    <!-- SUNAT -->
                    <Button Grid.Row="8"
                            Background="#4B5FD6"
                            Style="{StaticResource SideButtonStyle}"
                            Command="{Binding SunatCommand}">
                        <TextBlock Text="Sunat" Foreground="White"/>
                    </Button>

                    <!-- DNI -->
                    <Button Grid.Row="10"
                            Background="#4B5FD6"
                            Style="{StaticResource SideButtonStyle}"
                            Command="{Binding DniCommand}">
                        <TextBlock Text="D.n.I" Foreground="White"/>
                    </Button>

                    <!-- LOGO ABAJO -->
                    <StackPanel Grid.Row="12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image Width="70" Height="38"/>
                        <TextBlock Text="KapiConta"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>