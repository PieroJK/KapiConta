<UserControl x:Class="Inmobiliaria_KapiConta.Views.Login.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid  HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
        
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- 🔹 LADO IZQUIERDO -->
        <Grid Grid.Column="0" Background="#1E8C8A">

            <Image Source="pack://application:,,,/Assets/Login-removebg-preview.png"
                   Stretch="UniformToFill"/>

			<!-- Texto inferior -->
			<TextBlock Text="Sistema Contable Peruano 2026 © KapiConta"
                       Foreground="White"
                       FontSize="12"
                       Margin="10"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"/>
		</Grid>

		<!-- 🔹 LADO DERECHO -->
		<Grid Grid.Column="1" Background="#A7C7C6">

			<Border Background="#B8895B"
                    Width="350"
                    Padding="25"
                    CornerRadius="25"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

				<StackPanel>

					<!-- Título -->
					<TextBlock Text="INICIAR SESION"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1E1E1E"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

					<!-- Usuario -->
					<TextBlock Text="User name"
                               Foreground="#1E1E1E"
                               Margin="0,15,0,10"/>

					<TextBox Height="20"
                             Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderBrush="#333"
                             BorderThickness="0,0,0,1"/>
                    
                    <TextBlock Text="{Binding ErrorUsuario}"
                               Foreground="Red"
                               FontSize="11"/>

					<!-- Password -->
					<TextBlock Text="Password"
                               Foreground="#1E1E1E"
                               Margin="0,15,0,10"/>

                    <Grid Margin="0,0,0,5">

                        <!-- Password oculto -->
                        <PasswordBox x:Name="PasswordBox"
                                     Height="30"
                                     Padding="0,0,20,0"
                                     Background="Transparent"
                                     BorderBrush="#333"
                                     BorderThickness="0,0,0,1"/>

                        <!-- Password visible -->
                        <TextBox x:Name="VisiblePassword"
                                 Height="30"
                                 Padding="0,0,35,0"
                                 Visibility="Collapsed"
                                 Background="Transparent"
                                 BorderBrush="#333"
                                 BorderThickness="0,0,0,1"/>

                        <!-- Botón con ícono -->
                        <Button Width="30"
                                Height="30"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="TogglePasswordVisibility">

                            <TextBlock x:Name="EyeIcon"
                                 FontFamily="Segoe MDL2 Assets"
                                 Text="&#xE722;"
                                 FontSize="16"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"/>
                        </Button>

                    </Grid>

                    <TextBlock Text="{Binding ErrorPassword}"
                               Foreground="Red"
                               FontSize="11"/>

					<!-- Botón -->
					<Button Content="INGRESAR"
                            Height="40"
                            Margin="0,25,0,0"
                            Background="#F05A28"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="LoginButton_Click"/>

				</StackPanel>
			</Border>
		</Grid>
	</Grid>

</UserControl>