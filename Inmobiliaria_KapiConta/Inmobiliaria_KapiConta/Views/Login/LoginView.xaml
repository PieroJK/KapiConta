<UserControl x:Class="Inmobiliaria_KapiConta.Views.Login.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- 🔹 LADO IZQUIERDO -->
		<Grid Grid.Column="0" Background="#1E8C8A">

			<!-- Texto inferior -->
			<TextBlock Text="Sistema Contable Peruano 2026 © KapiConta"
                       Foreground="White"
                       FontSize="12"
                       Margin="10"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"/>
		</Grid>

		<!-- 🔹 LADO DERECHO -->
		<Grid Grid.Column="1" Background="#A7C7C6">

			<Border Background="#B8895B"
                    Width="350"
                    Padding="25"
                    CornerRadius="25"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

				<StackPanel>

					<!-- Título -->
					<TextBlock Text="INICIAR SESION"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#1E1E1E"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

					<!-- Usuario -->
					<TextBlock Text="User name"
                               Foreground="#1E1E1E"
                               Margin="0,10,0,0"/>

					<TextBox Height="35"
                             Background="Transparent"
                             BorderBrush="#333"
                             BorderThickness="0,0,0,1"
                             Foreground="Black"
                             FontSize="14"/>

					<!-- Password -->
					<TextBlock Text="Password"
                               Foreground="#1E1E1E"
                               Margin="0,15,0,0"/>

					<PasswordBox Height="35"
                                 Background="Transparent"
                                 BorderBrush="#333"
                                 BorderThickness="0,0,0,1"
                                 FontSize="14"/>

					<!-- Botón -->
					<Button Content="INGRESAR"
                            Height="40"
                            Margin="0,25,0,0"
                            Background="#F05A28"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"/>

				</StackPanel>
			</Border>
		</Grid>
	</Grid>

</UserControl>