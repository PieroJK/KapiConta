<UserControl x:Class="Inmobiliaria_KapiConta.Views.Login.ListadoUsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Item de la lista -->
        <Style x:Key="UserListItem" TargetType="ListViewItem">
            <Setter Property="Padding"                    Value="10,10"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="BorderThickness"            Value="0,0,0,1"/>
            <Setter Property="BorderBrush"                Value="#E0E0E0"/>
            <Setter Property="Background"                 Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E8F4F4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1E8C8A"/>
                                <Setter Property="Foreground"                  Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height"                    Value="44"/>
            <Setter Property="FontSize"                  Value="13"/>
            <Setter Property="Foreground"                Value="#1E1E1E"/>
            <Setter Property="Background"                Value="#EEF2F5"/>
            <Setter Property="BorderThickness"           Value="0,0,0,2"/>
            <Setter Property="BorderBrush"               Value="Transparent"/>
            <Setter Property="Padding"                   Value="12,0"/>
            <Setter Property="VerticalContentAlignment"  Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#999999"
                                           FontSize="13"
                                           Margin="13,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E8C8A"/>
                                <Setter TargetName="border" Property="Background"  Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E4EEF0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox -->
        <Style x:Key="InputPass" TargetType="PasswordBox">
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="#1E1E1E"/>
            <Setter Property="Background"               Value="#EEF2F5"/>
            <Setter Property="BorderThickness"          Value="0,0,0,2"/>
            <Setter Property="BorderBrush"              Value="Transparent"/>
            <Setter Property="Padding"                  Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <TextBlock x:Name="placeholder"
                                           Text="Nueva clave (opcional)"
                                           Foreground="#999999"
                                           FontSize="13"
                                           Margin="13,0,0,0"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"      Property="BorderBrush" Value="#1E8C8A"/>
                                <Setter TargetName="border"      Property="Background"  Value="White"/>
                                <Setter TargetName="placeholder" Property="Visibility"  Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height"                   Value="44"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="#1E1E1E"/>
            <Setter Property="Background"               Value="#EEF2F5"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="12,0,0,0"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="v"
                                           FontSize="11"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="White" CornerRadius="10" Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E4EEF0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding"  Value="12,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Cursor"   Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="bg" CornerRadius="7"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#E8F4F4"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#1E8C8A"/>
                                        <Setter Property="Foreground"                  Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Boton Modificar amarillo -->
        <Style x:Key="BtnModificar" TargetType="Button">
            <Setter Property="Background"      Value="#F5A623"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#D4891A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#B87315"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton Volver rojo -->
        <Style x:Key="BtnVolver" TargetType="Button">
            <Setter Property="Background"      Value="#E53935"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- FONDO PRINCIPAL -->
    <Grid Background="#1E3A4A">

        <!-- Borde decorativo inferior teal -->
        <Border Height="5" Background="#1E8C8A" VerticalAlignment="Bottom"/>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════
                 PANEL IZQUIERDO — LISTA BLANCA
            ═══════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera verde -->
                    <Border Grid.Row="0"
                            Background="#1E8C8A"
                            Padding="12,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Usuario"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Cod."
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Lista de usuarios -->
                    <ListView x:Name="LvUsuarios"
                              Grid.Row="1"
                              ItemContainerStyle="{StaticResource UserListItem}"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                              BorderThickness="0"
                              Background="White"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding NombreUsuario}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Estado}"
                                               FontSize="11"
                                               Foreground="#888888"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </Grid>
            </Border>

            <!-- ═══════════════════════════════
                 FORMULARIO DERECHA
            ═══════════════════════════════ -->
            <Border Grid.Column="2"
                    Background="#243B4A"
                    CornerRadius="16"
                    Padding="32,28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- CAMPOS -->
                    <StackPanel Grid.Column="0" Margin="0,0,24,0">

                        <!-- Titulo + codigo -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Listado Usuarios"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Background="#2E4D5E"
                                    CornerRadius="8"
                                    Padding="12,6">
                                <TextBlock Text="{Binding SelectedUser.Id}"
                                           FontSize="13"
                                           Foreground="#AAAAAA"
                                           FontFamily="Consolas"/>
                            </Border>
                        </Grid>

                        <!-- Nombre usuario -->
                        <TextBox Style="{StaticResource InputBox}"
                                 Tag="Nombre Usuario"
                                 Text="{Binding SelectedUser.Nombre, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <!-- Clave -->
                        <PasswordBox x:Name="PbClave"
                                     Style="{StaticResource InputPass}"
                                     Margin="0,0,0,12"/>

                        <!-- Nombre empleado -->
                        <TextBox Style="{StaticResource InputBox}"
                                 Tag="Nombre empleado"
                                 Text="{Binding SelectedUser.Nombre, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <!-- Rol + Estado en fila -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      Style="{StaticResource InputCombo}"
                                      SelectedValue="{Binding SelectedUser.Rol.Nombre}">
                                <ComboBoxItem Content="Administrador"/>
                                <ComboBoxItem Content="Contador"/>
                                <ComboBoxItem Content="Auxiliar"/>
                                <ComboBoxItem Content="Solo lectura"/>
                            </ComboBox>

                            <ComboBox Grid.Column="2"
                                      Style="{StaticResource InputCombo}"
                                      SelectedValue="{Binding SelectedUser.Estado}">
                                <ComboBoxItem Content="Activo"/>
                                <ComboBoxItem Content="Inactivo"/>
                            </ComboBox>
                        </Grid>

                        <!-- Mensaje error 
                        <TextBlock Text="{Binding MensajeError}"
                                   Foreground="#FF6B6B"
                                   FontSize="12"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HayError}"/>-->

                        <!-- Botones -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource BtnVolver}"
                                    Content="Volver"
                                    Command="{Binding VolverCommand}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource BtnModificar}"
                                    Content="Modificar"
                                    Command="{Binding ModificarCommand}"/>
                        </Grid>

                    </StackPanel>

                    <!-- LOGO -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="130">
                        <Image Source="pack://application:,,,/Assets/Login-removebg-preview.png"
                               Width="110"
                               Height="110"
                               Stretch="Uniform"
                               Margin="0,0,0,8"/>
                        <TextBlock Text="KapiConta"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>