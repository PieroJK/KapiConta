<UserControl x:Class="Inmobiliaria_KapiConta.Views.Login.RegistrarUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Estilo TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height"           Value="44"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Foreground"       Value="#1E1E1E"/>
            <Setter Property="Background"       Value="#EEF2F5"/>
            <Setter Property="BorderThickness"  Value="0,0,0,2"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#999999"
                                           FontSize="13"
                                           Margin="13,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E8C8A"/>
                                <Setter TargetName="border" Property="Background"  Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E4EEF0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo PasswordBox -->
        <Style x:Key="InputPass" TargetType="PasswordBox">
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#1E1E1E"/>
            <Setter Property="Background"      Value="#EEF2F5"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <TextBlock x:Name="placeholder"
                                           Text="Clave"
                                           Foreground="#999999"
                                           FontSize="13"
                                           Margin="13,0,0,0"
                                           VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"      Property="BorderBrush" Value="#1E8C8A"/>
                                <Setter TargetName="border"      Property="Background"  Value="White"/>
                                <Setter TargetName="placeholder" Property="Visibility"  Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo ComboBox -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#1E1E1E"/>
            <Setter Property="Background"      Value="#EEF2F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="12,0,0,0"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="▼"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="White"
                                            CornerRadius="10"
                                            Padding="4">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen,
                                                  RelativeSource={RelativeSource TemplatedParent},
                                                  Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E4EEF0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding"   Value="12,8"/>
                    <Setter Property="FontSize"  Value="13"/>
                    <Setter Property="Cursor"    Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="bg" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#E8F4F4"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#1E8C8A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Boton Registrar (verde) -->
        <Style x:Key="BtnRegistrar" TargetType="Button">
            <Setter Property="Background"      Value="#27AE60"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#219A52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A7D42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton Volver (rojo) -->
        <Style x:Key="BtnVolver" TargetType="Button">
            <Setter Property="Background"      Value="#E53935"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C62828"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- FONDO PRINCIPAL -->
    <Grid Background="#1E3A4A">

        <!-- Borde decorativo izquierdo (teal) -->
        <Border Width="6"
                Background="#1E8C8A"
                HorizontalAlignment="Left"
                CornerRadius="0,0,0,0"/>

        <!-- Borde decorativo inferior (teal) -->
        <Border Height="5"
                Background="#1E8C8A"
                VerticalAlignment="Bottom"/>

        <!-- TARJETA CENTRAL -->
        <Border MaxWidth="560"
                Margin="60,40"
                Background="#243B4A"
                CornerRadius="20"
                Padding="40,36">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- FORMULARIO -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">

                    <!-- Titulo -->
                    <TextBlock Text="Registrar Usuario"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,28"/>

                    <!-- Nombre Usuario -->
                    <TextBox x:Name="TxtNombreUsuario"
                             Style="{StaticResource InputBox}"
                             Tag="Nombre Usuario"
                             Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <!-- Clave -->
                    <PasswordBox x:Name="PbClave"
                                 Style="{StaticResource InputPass}"
                                 Margin="0,0,0,14"/>

                    <!-- Nombre Empleado -->
                    <TextBox x:Name="TxtNombreEmpleado"
                             Style="{StaticResource InputBox}"
                             Tag="Nombre empleado"
                             Text="{Binding NombreEmpleado, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <!-- Rol -->
                    <ComboBox x:Name="CmbRol"
                              Style="{StaticResource InputCombo}"
                              SelectedItem="{Binding RolSeleccionado}"
                              Margin="0,0,0,32">
                        <ComboBoxItem Content="Administrador" IsSelected="True"/>
                        <ComboBoxItem Content="Contador"/>
                        <ComboBoxItem Content="Auxiliar"/>
                        <ComboBoxItem Content="Solo lectura"/>
                    </ComboBox>

                    <!-- Mensaje de error -->
                    <TextBlock x:Name="TxtError"
                               Text="{Binding MensajeError}"
                               Foreground="#FF6B6B"
                               FontSize="12"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Visibility="{Binding HayError}"/>

                    <!-- Botones -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource BtnVolver}"
                                Content="Volver"
                                Command="{Binding VolverCommand}"/>

                        <Button Grid.Column="2"
                                Style="{StaticResource BtnRegistrar}"
                                Content="Registrar"
                                Command="{Binding RegistrarCommand}"
                                />
                    </Grid>

                </StackPanel>

                <!-- LOGO KAPICONTA -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="130">
                    <Image Source="pack://application:,,,/Assets/Login-removebg-preview.png"
                           Width="110"
                           Height="110"
                           Stretch="Uniform"
                           Margin="0,0,0,8"/>
                    <TextBlock Text="KapiConta"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
