<UserControl x:Class="Inmobiliaria_KapiConta.Views.Login.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<UserControl.Resources>

		<!-- NAV BUTTON normal -->
		<Style x:Key="NavBtn" TargetType="Button">
			<Setter Property="Background"                Value="Transparent"/>
			<Setter Property="Foreground"                Value="#CCFFFFFF"/>
			<Setter Property="BorderThickness"           Value="0"/>
			<Setter Property="Height"                    Value="40"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Padding"                   Value="18,0"/>
			<Setter Property="FontSize"                  Value="12"/>
			<Setter Property="Cursor"                    Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Margin="6,1">
							<ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- NAV BUTTON activo -->
		<Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
			<Setter Property="Background" Value="#B8895B"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>

		<!-- BOTON NARANJA -->
		<Style x:Key="OrangeBtn" TargetType="Button">
			<Setter Property="Background"      Value="#F05A28"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Height"          Value="34"/>
			<Setter Property="FontWeight"      Value="Bold"/>
			<Setter Property="FontSize"        Value="11"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="14,0">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- BOTON ROJO -->
		<Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource OrangeBtn}">
			<Setter Property="Background" Value="#E53935"/>
		</Style>

	</UserControl.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="220"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- SIDEBAR -->
		<Border Grid.Column="0" Background="#155F5E">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- MARCA -->
				<Border Grid.Row="0" Background="#1E8C8A" Padding="16,18">
					<StackPanel Orientation="Horizontal">
						<Border Width="38" Height="38"
                                Background="#B8895B"
                                CornerRadius="9">
							<TextBlock Text="K"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
							<TextBlock Text="KapiConta"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"/>
							<TextBlock Text="Sistema Contable 2026"
                                       Foreground="#88FFFFFF"
                                       FontSize="10"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- NAVEGACION -->
				<ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              Padding="0,6,0,0">
					<StackPanel>
						<TextBlock Text="EMPRESAS"
                                   Foreground="#77FFFFFF" FontSize="9" FontWeight="Bold"
                                   Margin="22,12,0,2"/>
						<Button Style="{StaticResource NavBtnActive}" Content="  Inicio / Dashboard"/>
						<Button Style="{StaticResource NavBtn}"       Content="  Registrar empresa"
                                Command="{Binding RegistrarEmpresaCommand}"/>
						<Button Style="{StaticResource NavBtn}"       Content="  Listado empresa"
                                Command="{Binding ListadoEmpresaCommand}"/>
						<Button Style="{StaticResource NavBtn}"       Content="  Registrar usuario"
                                Command="{Binding RegistrarUsuarioCommand}"/>
						<Button Style="{StaticResource NavBtn}"       Content="  Listado usuario"
                                Command="{Binding ListadoUsuarioCommand}"/>

						<TextBlock Text="PROCESOS"
                                   Foreground="#77FFFFFF" FontSize="9" FontWeight="Bold"
                                   Margin="22,12,0,2"/>
						<Button Style="{StaticResource NavBtn}" Content="  Procesos contables"/>
						<Button Style="{StaticResource NavBtn}" Content="  Gestion de archivos"/>

						<TextBlock Text="REGISTRO"
                                   Foreground="#77FFFFFF" FontSize="9" FontWeight="Bold"
                                   Margin="22,12,0,2"/>
						<Button Style="{StaticResource NavBtn}" Content="  Nuevo registro"/>
						<Button Style="{StaticResource NavBtn}" Content="  Buscar registros"/>

						<TextBlock Text="LISTADO"
                                   Foreground="#77FFFFFF" FontSize="9" FontWeight="Bold"
                                   Margin="22,12,0,2"/>
						<Button Style="{StaticResource NavBtn}" Content="  Ver listados"/>
						<Button Style="{StaticResource NavBtn}" Content="  Exportar datos"/>

						<TextBlock Text="UTILIDADES"
                                   Foreground="#77FFFFFF" FontSize="9" FontWeight="Bold"
                                   Margin="22,12,0,2"/>
						<Button Style="{StaticResource NavBtn}" Content="  Configuracion"/>
						<Button Style="{StaticResource NavBtn}" Content="  Reportes"/>
					</StackPanel>
				</ScrollViewer>

				<!-- FOOTER SIDEBAR -->
				<Border Grid.Row="2" Background="#0F4A49" Padding="14,12">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel Orientation="Horizontal">
							<Border Width="32" Height="32" Background="#B8895B" CornerRadius="16">
								<TextBlock Text="U" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
							<StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
								<TextBlock Text="{Binding UsuarioActual}"
                                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
								<TextBlock Text="Cuenta activa"
                                           Foreground="#77FFFFFF" FontSize="10"/>
							</StackPanel>
						</StackPanel>
						<Button Grid.Column="1"
                                Content="Salir"
                                FontSize="11" FontWeight="Bold"
                                Background="Transparent"
                                Foreground="#FF6B6B"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Cerrar Sesion"
                                Command="{Binding CerrarSesionCommand}"/>
					</Grid>
				</Border>
			</Grid>
		</Border>

		<!-- CONTENIDO PRINCIPAL -->
		<Grid Grid.Column="1" Background="#E8F4F4">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- TOPBAR -->
			<Border Grid.Row="0" Background="White" Padding="24,12">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<StackPanel>
						<TextBlock Text="Bienvenido al Dashboard"
                                   FontSize="18" FontWeight="Bold" Foreground="#1E1E1E"/>
						<TextBlock Text="Sistema Contable Peruano 2026"
                                   FontSize="11" Foreground="#888888"/>
					</StackPanel>
					<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
						<Border Background="#E8F4F4" CornerRadius="7" Padding="10,5" Margin="0,0,10,0">
							<TextBlock Text="{Binding FechaActual}" FontSize="11" Foreground="#555555"/>
						</Border>
						<Border Background="#B8895B" CornerRadius="7" Padding="10,5">
							<TextBlock Text="{Binding EmpresaActual}"
                                       FontSize="11" Foreground="White" FontWeight="SemiBold"/>
						</Border>
					</StackPanel>
				</Grid>
			</Border>

			<!-- SCROLL AREA -->
			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,20,22,20">
				<StackPanel>

					<!-- TARJETAS ESTADISTICAS -->
					<Grid Margin="0,0,0,22">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Border Grid.Column="0" Background="#1A7A78" CornerRadius="14"
                                Padding="18,16" Margin="0,0,8,0">
							<StackPanel>
								<TextBlock Text="Empresas"    Foreground="#AAFFFFFF" FontSize="11"/>
								<TextBlock Text="{Binding TotalEmpresas}"
                                           FontSize="30" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
								<TextBlock Text="registradas" Foreground="#AAFFFFFF" FontSize="11"/>
							</StackPanel>
						</Border>

						<Border Grid.Column="1" Background="#B8895B" CornerRadius="14"
                                Padding="18,16" Margin="0,0,8,0">
							<StackPanel>
								<TextBlock Text="Usuarios"  Foreground="#AAFFFFFF" FontSize="11"/>
								<TextBlock Text="{Binding TotalUsuarios}"
                                           FontSize="30" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
								<TextBlock Text="activos"   Foreground="#AAFFFFFF" FontSize="11"/>
							</StackPanel>
						</Border>

						<Border Grid.Column="2" Background="#1E8C8A" CornerRadius="14"
                                Padding="18,16" Margin="0,0,8,0">
							<StackPanel>
								<TextBlock Text="Registros" Foreground="#AAFFFFFF" FontSize="11"/>
								<TextBlock Text="{Binding TotalRegistros}"
                                           FontSize="30" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
								<TextBlock Text="del mes"   Foreground="#AAFFFFFF" FontSize="11"/>
							</StackPanel>
						</Border>

						<Border Grid.Column="3" Background="#F05A28" CornerRadius="14" Padding="18,16">
							<StackPanel>
								<TextBlock Text="Procesos"   Foreground="#AAFFFFFF" FontSize="11"/>
								<TextBlock Text="{Binding ProcesosPendientes}"
                                           FontSize="30" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
								<TextBlock Text="pendientes" Foreground="#AAFFFFFF" FontSize="11"/>
							</StackPanel>
						</Border>
					</Grid>

					<!-- ACCESOS RAPIDOS -->
					<TextBlock Text="Accesos Rapidos"
                               FontSize="14" FontWeight="Bold" Foreground="#1E1E1E" Margin="0,0,0,14"/>

					<WrapPanel>
						<!-- Registrar empresa -->
						<Border Width="185" Background="White" CornerRadius="12" Padding="16" Margin="0,0,12,12">
							<StackPanel>
								<Border Width="40" Height="40" Background="#D5EDED" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
									<TextBlock Text="E+" FontSize="16" FontWeight="Bold" Foreground="#1A7A78"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Registrar empresa"  FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4"/>
								<TextBlock Text="Anadir nueva empresa" FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
								<Button Style="{StaticResource OrangeBtn}" Content="Ir"
                                        Command="{Binding RegistrarEmpresaCommand}"/>
							</StackPanel>
						</Border>

						<!-- Listado empresa -->
						<Border Width="185" Background="White" CornerRadius="12" Padding="16" Margin="0,0,12,12">
							<StackPanel>
								<Border Width="40" Height="40" Background="#F5E9DA" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
									<TextBlock Text="EL" FontSize="16" FontWeight="Bold" Foreground="#B8895B"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Listado empresa"      FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4"/>
								<TextBlock Text="Ver todas las empresas" FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
								<Button Style="{StaticResource OrangeBtn}" Content="Ir"
                                        Command="{Binding ListadoEmpresaCommand}"/>
							</StackPanel>
						</Border>

						<!-- Registrar usuario -->
						<Border Width="185" Background="White" CornerRadius="12" Padding="16" Margin="0,0,12,12">
							<StackPanel>
								<Border Width="40" Height="40" Background="#D5EDED" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
									<TextBlock Text="U+" FontSize="16" FontWeight="Bold" Foreground="#1A7A78"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Nuevo usuario"    FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4"/>
								<TextBlock Text="Registrar usuario" FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
								<Button Style="{StaticResource OrangeBtn}" Content="Ir"
                                        Command="{Binding RegistrarUsuarioCommand}"/>
							</StackPanel>
						</Border>

						<!-- Listado usuario -->
						<Border Width="185" Background="White" CornerRadius="12" Padding="16" Margin="0,0,12,12">
							<StackPanel>
								<Border Width="40" Height="40" Background="#F5E9DA" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
									<TextBlock Text="UL" FontSize="16" FontWeight="Bold" Foreground="#B8895B"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Listado usuario"      FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4"/>
								<TextBlock Text="Ver todos los usuarios" FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
								<Button Style="{StaticResource OrangeBtn}" Content="Ir"
                                        Command="{Binding ListadoUsuarioCommand}"/>
							</StackPanel>
						</Border>

						<!-- Ingresar empresa -->
						<Border Width="185" Background="White" CornerRadius="12" Padding="16" Margin="0,0,12,12">
							<StackPanel>
								<Border Width="40" Height="40" Background="#D5EDED" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
									<TextBlock Text="IE" FontSize="16" FontWeight="Bold" Foreground="#1A7A78"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Ingresar empresa" FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4"/>
								<TextBlock Text="Acceder al modulo"  FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
								<Button Style="{StaticResource OrangeBtn}" Content="Ir"
                                        Command="{Binding IngresarEmpresaCommand}"/>
							</StackPanel>
						</Border>

						<!-- Cerrar Sesion -->
						<Border Width="185" Background="#FFF0F0" CornerRadius="12" Padding="16" Margin="0,0,12,12">
							<StackPanel>
								<Border Width="40" Height="40" Background="#FFE0E0" CornerRadius="10"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
									<TextBlock Text="X" FontSize="18" FontWeight="Bold" Foreground="#E53935"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Cerrar Sesion"         FontSize="12" FontWeight="SemiBold" Foreground="#1E1E1E" Margin="0,0,0,4"/>
								<TextBlock Text="Salir de la sesion actual" FontSize="11" Foreground="#888888" Margin="0,0,0,12"/>
								<Button Style="{StaticResource RedBtn}" Content="Salir"
                                        Command="{Binding CerrarSesionCommand}"/>
							</StackPanel>
						</Border>
					</WrapPanel>

					<!-- FOOTER -->
					<TextBlock Text="Sistema Contable Peruano 2026 © KapiConta"
                               Foreground="#AAAAAA" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,16,0,4"/>

				</StackPanel>
			</ScrollViewer>
		</Grid>
	</Grid>
</UserControl>
