<UserControl x:Class="Inmobiliaria_KapiConta.Views.GestionAsiento.ImportarAiento"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             Background="#202020">

    <Grid Margin="20">
        <Border Background="#2D2D2D" CornerRadius="10" Padding="20">
            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Importar Asientos desde Excel"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <!-- Archivo -->
                <TextBlock Text="Archivo Excel" Foreground="#CCCCCC"/>
                <DockPanel Margin="0,5,0,15">
                    <Button Content="📂"
                            Width="40"
                            Margin="10,0,0,0"
                            Background="#3A3A3A"
                            Foreground="White"
                            BorderBrush="#555"
                            DockPanel.Dock="Right"
                            Command="{Binding SeleccionarArchivoCommand}"/>
                    <TextBox Height="30"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderBrush="#444"
                             IsReadOnly="True"
                             Padding="5"
                             Text="{Binding RutaArchivo}"/>
                </DockPanel>

                <!-- Subdiario -->
                <TextBlock Text="Subdiario" Foreground="#CCCCCC"/>
                <ComboBox Height="30"
                          Margin="0,5,0,15"
                          Background="#1E1E1E"
                          BorderBrush="#444"
                          ItemsSource="{Binding SubDiarios}"
                          SelectedItem="{Binding SubDiarioSeleccionado}"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="IdSubDiario">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <!-- Mes -->
                <TextBlock Text="Mes" Foreground="#CCCCCC"/>
                <ComboBox Height="30"
                          Margin="0,5,0,15"
                          Background="#1E1E1E"
                          BorderBrush="#444"
                          ItemsSource="{Binding Meses}"
                          SelectedItem="{Binding MesSeleccionado}"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="IdMes">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <!-- Modo -->
                <TextBlock Text="Modo de importación" Foreground="#CCCCCC"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                    <RadioButton Content="Inicio"
                                 Foreground="White"
                                 IsChecked="{Binding ModoInicio}"
                                 Margin="0,0,20,0"/>
                    <RadioButton Content="Continuar correlativo"
                                 Foreground="White"
                                 IsChecked="{Binding ModoContinuar}"/>
                </StackPanel>

                <!-- Botón -->
                <Button Content="IMPORTAR"
                        Height="40"
                        Background="#007ACC"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Command="{Binding ImportarCommand}"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
