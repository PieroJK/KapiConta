<UserControl x:Class="Inmobiliaria_KapiConta.Views.Periodo.SeleccionPeriodoView"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#149191">
        <Border Width="500"
                Padding="30"
                CornerRadius="20"
                Background="#DDDDDD"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="SELECCIONAR PERIODO"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Periodo"
                           FontSize="16"
                           Margin="0,0,0,10"/>

                <ComboBox Height="35"
                          ItemsSource="{Binding Periodos}"
                          SelectedItem="{Binding PeriodoSeleccionado}"
                          DisplayMemberPath="Anio"/>

                <Button Content="INGRESAR"
                        Height="40"
                        Margin="0,25,0,0"
                        Background="#F05A28"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Command="{Binding ContinuarCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
