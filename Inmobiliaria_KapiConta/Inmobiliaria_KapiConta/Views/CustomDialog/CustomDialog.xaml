<Window x:Class="Inmobiliaria_KapiConta.Views.CustomDialog.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helper="clr-namespace:Inmobiliaria_KapiConta.Helpers.Converters"
        mc:Ignorable="d"
        Title="{Binding Model.Title}"
        Height="Auto" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>

        


        <!-- Convertidor para el icono según el tipo -->
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
            </Style>
    </Window.Resources>
    <Border Background="White" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icono según el tipo -->
            <Border Grid.Row="0" Grid.Column="0" 
                    Width="48" Height="48" 
                    Margin="0,0,15,0"
                    CornerRadius="24">

                <!-- El fondo cambia según el tipo -->
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#2196F3"/>
                        <!-- Default -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Model.Type}" Value="Success">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.Type}" Value="Error">
                                <Setter Property="Background" Value="#F44336"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.Type}" Value="Warning">
                                <Setter Property="Background" Value="#FF9800"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.Type}" Value="Information">
                                <Setter Property="Background" Value="#2196F3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Model.Type}" Value="Question">
                                <Setter Property="Background" Value="#9C27B0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <!-- El ícono cambia según el tipo usando un ContentControl -->
                <ContentControl>
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <TextBlock Text="ℹ" Style="{StaticResource IconStyle}"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Model.Type}" Value="Success">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <TextBlock Text="✓" Style="{StaticResource IconStyle}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Model.Type}" Value="Error">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <TextBlock Text="✗" Style="{StaticResource IconStyle}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Model.Type}" Value="Warning">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <TextBlock Text="⚠" Style="{StaticResource IconStyle}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Model.Type}" Value="Question">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <TextBlock Text="?" Style="{StaticResource IconStyle}"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>

            <!-- Mensaje principal -->
            <TextBlock Grid.Row="0" Grid.Column="1" 
                       Text="{Binding Model.Message}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>

            <!-- Detalles técnicos (expandible) -->
            <Expander Grid.Row="1" Grid.ColumnSpan="2" 
                      Header="Ver detalles"
                      Margin="0,15,0,0"
                      >
                <TextBox Text="{Binding Model.Details}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="11"
                         TextWrapping="Wrap"
                         MaxHeight="150"
                         Background="#F5F5F5"/>
            </Expander>

            <!-- Botones -->
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <!-- Botón Aceptar/OK -->
                <Button Content="Aceptar"
                        Command="{Binding AcceptCommand}"
                        Width="80" Height="30"
                        Margin="5,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Model.Type}" Value="Error">
                                    <Setter Property="Background" Value="#F44336"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Model.Type}" Value="Success">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Botón Cancelar (solo si ShowConfirmButtons es true) -->
                <Button Content="Cancelar"
                        Command="{Binding CancelCommand}"
                        Width="80" Height="30"
                        Margin="5,0,0,0"
                        />
            </StackPanel>
        </Grid>
    </Border>
</Window>
