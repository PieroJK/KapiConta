<UserControl x:Class="Inmobiliaria_KapiConta.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Inmobiliaria_KapiConta.Views.Dashboard"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid>

        <!-- FONDO -->
        <Rectangle Fill="#149191"/>

        <!-- IMAGEN -->
        <Image Source="/Assets/capibara.png"
           Stretch="Uniform"
           Width="900"
           Opacity="0.18"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            

            <!-- MENU -->
            <Menu Grid.Row="0" Background="#DDDDDD">

                <Menu.Resources>
                    <!-- Estilo del header principal -->
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="#DDDDDD"/>
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>

                    <!-- Estilo de las opciones del submenú -->
                    <Style x:Key="SubMenuItemStyle" TargetType="MenuItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#B38757"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="BorderBrush" Value="#6E5337"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#9F764C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Menu.Resources>
                
                <MenuItem Header="Empresas">
                    <MenuItem Header="Registrar nueva empresa" Style="{StaticResource SubMenuItemStyle}"
                              Command="{Binding RegisterEnterpriseCommand}">
                    </MenuItem>
                    <MenuItem Header="Listado empresa" Style="{StaticResource SubMenuItemStyle}"
                              Command="{Binding ListEnterpriseCommand}"></MenuItem>
                    <MenuItem Header="Registrar usuario" Style="{StaticResource SubMenuItemStyle}"></MenuItem>
                    <MenuItem Header="Listado usuario" Style="{StaticResource SubMenuItemStyle}"
                              Command="{Binding ListUsersCommand}"></MenuItem>
                    <MenuItem Header="Ingresar nueva empresa" Style="{StaticResource SubMenuItemStyle}"></MenuItem>
                </MenuItem>
                <MenuItem Header="Procesos">
                    <MenuItem Header="Ingresar Asiento" Style="{StaticResource SubMenuItemStyle}"></MenuItem>
                    <MenuItem Header="Importar Asiento" Style="{StaticResource SubMenuItemStyle}" Command="{Binding ImportarAsientoCommand }"></MenuItem>
                </MenuItem>
                
                <MenuItem Header="Registro" Click="MenuItem_Click">

                    <MenuItem Header="Plan de Cuentas" Style="{StaticResource SubMenuItemStyle}"
                          Command="{Binding PlanCuentasCommand}"/>

                    <MenuItem Header="Terceros" Style="{StaticResource SubMenuItemStyle}">

                        <MenuItem Header="Registrar Terceros" Style="{StaticResource SubMenuItemStyle}"
                              Command="{Binding RegistrarTercerosCommand}"/>

                        <MenuItem Header="Listado Terceros" Style="{StaticResource SubMenuItemStyle}"
                              Command="{Binding ListadoTercerosCommand}"/>

                    </MenuItem>

                </MenuItem>
                <MenuItem Header="Listado">
                    
                </MenuItem>
                <MenuItem Header="Utilidades"></MenuItem>
                

            </Menu>

            <!-- CONTENIDO -->
            <TabControl Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Tabs}"
            SelectedItem="{Binding TabSeleccionado}"
            Margin="10">

                <!-- HEADER -->
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Titulo}" Margin="0,0,5,0"/>
                            <Button Content="X"
                        Width="18"
                        Height="18"
                        Command="{Binding DataContext.CerrarTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                        CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <!-- 🔥 ESTA PARTE FALTABA -->
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding Contenido}"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>

            </TabControl>

            <!-- FOOTER -->
            <Grid Grid.Row="2" Background="#DDDDDD">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Sistema Contable Peruano 2026 © KapiConta"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>

                <TextBlock Text="{Binding Usuario}"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Empresa}"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="{Binding Periodo}"
                       Grid.Column="3"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
