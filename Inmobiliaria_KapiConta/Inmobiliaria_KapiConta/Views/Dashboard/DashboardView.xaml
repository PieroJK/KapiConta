<UserControl x:Class="Inmobiliaria_KapiConta.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Inmobiliaria_KapiConta.Views.Dashboard"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid>

        <!-- FONDO -->
        <Rectangle Fill="#149191"/>

        <!-- IMAGEN -->
        <Image Source="/Assets/capibara.png"
           Stretch="Uniform"
           Width="900"
           Opacity="0.18"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- 🔝 MENU -->
            <Menu Grid.Row="0" Background="#DDDDDD">

                <MenuItem Header="Empresas"></MenuItem>
                <MenuItem Header="Procesos">
                    <MenuItem Header="Ingresar Asiento"></MenuItem>
                    <MenuItem Header="Importar Asiento"></MenuItem>
                </MenuItem>
                
                <MenuItem Header="Registro" Click="MenuItem_Click">

                    <MenuItem Header="Plan de Cuentas"
                          Command="{Binding PlanCuentasCommand}"/>

                    <MenuItem Header="Terceros">

                        <MenuItem Header="Registrar Terceros"
                              Command="{Binding RegistrarTercerosCommand}"/>

                        <MenuItem Header="Listado Terceros"
                              Command="{Binding ListadoTercerosCommand}"/>

                    </MenuItem>

                </MenuItem>
                <MenuItem Header="Listado">
                    
                </MenuItem>
                <MenuItem Header="Utilidades"></MenuItem>
                

            </Menu>

            <!-- CONTENIDO -->
            <TabControl Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Tabs}"
            SelectedItem="{Binding TabSeleccionado}"
            Margin="10">

                <!-- HEADER -->
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Titulo}" Margin="0,0,5,0"/>
                            <Button Content="X"
                        Width="18"
                        Height="18"
                        Command="{Binding DataContext.CerrarTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                        CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <!-- 🔥 ESTA PARTE FALTABA -->
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding Contenido}"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>

            </TabControl>

            <!-- FOOTER -->
            <Grid Grid.Row="2" Background="#DDDDDD">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Sistema Contable Peruano 2026 © KapiConta"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>

                <TextBlock Text="{Binding Usuario}"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Empresa}"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="{Binding Periodo}"
                       Grid.Column="3"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
