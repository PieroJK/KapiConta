<Window x:Class="Inmobiliaria_KapiConta.Views.PlanCuentas.AgregarAsientoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Agregar Asiento"
Height="500"
Width="760"
WindowStartupLocation="CenterOwner"
ResizeMode="NoResize"
Background="#2F2F31">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Seleccionar cuenta para automatización"
               Foreground="White"
               FontSize="22"
               FontWeight="SemiBold"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Buscar"
                   Foreground="White"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="txtBuscar"
                 Grid.Column="1"
                 Height="34"
                 Background="#DDDDDD"
                 BorderThickness="0"
                 VerticalContentAlignment="Center"
                 TextChanged="txtBuscar_TextChanged"/>
        </Grid>

        <Border Grid.Row="4"
            Background="White"
            BorderBrush="Black"
            BorderThickness="1">
            <DataGrid x:Name="dgCuentas"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="dgCuentas_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"
                                    Binding="{Binding Codigo}"
                                    Width="120"/>
                    <DataGridTextColumn Header="Descripción"
                                    Binding="{Binding Descripcion}"
                                    Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Tipo"
                   Foreground="White"
                   VerticalAlignment="Center"/>

            <ComboBox x:Name="cbTipo"
                  Grid.Column="1"
                  Height="34"
                  Background="#DDDDDD"
                  BorderThickness="0"
                  SelectedIndex="0">
                <ComboBoxItem Content="Debe" Tag="D"/>
                <ComboBoxItem Content="Haber" Tag="H"/>
            </ComboBox>

            <TextBlock Grid.Column="3"
                   Text="%"
                   Foreground="White"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="txtPorcentaje"
                 Grid.Column="4"
                 Height="34"
                 Background="#DDDDDD"
                 BorderThickness="0"
                 VerticalContentAlignment="Center"
                 Text="100"/>

            <StackPanel Grid.Column="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                <Button x:Name="btnAceptar"
                    Content="Aceptar"
                    Width="110"
                    Height="38"
                    Margin="0,0,10,0"
                    Background="#2BC353"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="btnAceptar_Click"/>

                <Button x:Name="btnCancelar"
                    Content="Cancelar"
                    Width="110"
                    Height="38"
                    Background="#D94A3A"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="btnCancelar_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
