<UserControl x:Class="Inmobiliaria_KapiConta.Views.PlanCuentas.PlanCuentasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#2F4A5A">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*"/>
            <ColumnDefinition Width="1.05*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO -->
        <Grid Grid.Column="0" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Plan de Cuentas"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="6,0,0,16"/>

            <Border Grid.Row="1"
                Background="#F2F2F2"
                BorderBrush="Black"
                BorderThickness="2">
                <DataGrid x:Name="dgPlanCuentas"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeight="28"
                  FontSize="12"
                  ItemsSource="{Binding PlanCuentas}"
                  SelectedItem="{Binding CuentaSeleccionada, Mode=TwoWay}">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EsBase}" Value="True">
                                    <Setter Property="Foreground" Value="#2563EB"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                        <DataGridTextColumn Header="Nivel" Binding="{Binding Nivel}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="10,8,0,0">
                <Button x:Name="btnVolver"
                    Content="Volver"
                    Width="110"
                    Height="42"
                    Margin="10,0,20,0"
                    Background="#E5533D"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Command="{Binding VolverCommand}"/>

                <Button x:Name="btnBuscar"
                    Content="Buscar"
                    Width="110"
                    Height="42"
                    Background="#5067F0"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Command="{Binding BuscarCommand}"/>
            </StackPanel>
        </Grid>

        <!-- PANEL DERECHO -->
        <Border Grid.Column="1"
            Background="#2F2F31"
            BorderBrush="#8C6239"
            BorderThickness="1,0,0,0">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="78"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CABECERA -->
                <Grid Grid.Row="0">
                    <Border BorderBrush="#8C6239" BorderThickness="0,0,0,1"/>
                    <TextBlock Text="Datos de Plan de&#x0a;Cuentas"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="16,10,0,0"/>
                    <Image Source="/Assets/logo.png"
                       Width="120"
                       Height="48"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,10,12,0"/>
                </Grid>

                <!-- CUERPO -->
                <Grid Grid.Row="1" Margin="16,18,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="0.95*"/>
                    </Grid.ColumnDefinitions>

                    <!-- IZQUIERDA: DATOS -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- CUENTA -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Cuenta"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <TextBox 
                                 Grid.Column="1"
                                 Height="34"
                                 Margin="0,0,10,0"
                                 Background="#DDDDDD"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding Codigo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- BOTONES -->
                        <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left">
                            <Button 
                                Content="Agregar"
                                Width="95"
                                Height="44"
                                Background="#2BC353"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="15"
                                FontWeight="Bold"
                                Command="{Binding AgregarCommand}"/>

                            <Button 
                                Content="Modificar"
                                Width="105"
                                Height="44"
                                Margin="10,0,0,0"
                                Background="#E7C315"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="15"
                                FontWeight="Bold"
                                Command="{Binding ModificarCommand}"/>

                            <Button 
                                Content="Eliminar"
                                Width="95"
                                Height="44"
                                Margin="10,0,0,0"
                                Background="#D94A3A"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="15"
                                FontWeight="Bold"
                                Command="{Binding EliminarCommand}"/>
                        </StackPanel>

                        <!-- DESCRIPCIÓN -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Descripción"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <TextBox x:Name="txtDescripcion"
                                     Grid.Column="1"
                                     Height="34"
                                     Background="#DDDDDD"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Descripcion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- NIVEL -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nivel"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <TextBox Text="{Binding Nivel}" 
                                 IsReadOnly="True"
                                 Grid.Column="1"
                                 Width="80"
                                 Height="34"
                                 Background="#DDDDDD"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- CUENTA PADRE -->
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Cnt. Padre"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <ComboBox 
                                  ItemsSource="{Binding CuentasPadre}"
                                  SelectedValue="{Binding CodigoPadre}"
                                  SelectedValuePath="Codigo"
                                  DisplayMemberPath="Descripcion"
                                  Grid.Column="1"
                                  Height="38"
                                  Background="#DDDDDD"
                                  BorderThickness="0"
                                  />
                        </Grid>

                        <!-- ANALISIS -->
                        <Grid Grid.Row="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Análisis"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Height="38"
                                    Background="#DDDDDD"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    Padding="8,0">

                                <CheckBox Content="Sí"
                                          IsChecked="{Binding Analisis}"
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <!-- ELEMENTO Y BALANCE -->
                        <Grid Grid.Row="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Elemento"
                                   Grid.Row="0"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <ComboBox 
                                  ItemsSource="{Binding Elementos}"
                                  SelectedItem="{Binding ElementoSeleccionado}"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Height="38"
                                  Background="#DDDDDD"
                                  BorderThickness="0"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="IdElemento"/>

                            <TextBlock Text="Balance"
                                   Grid.Row="2"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                            <ComboBox 
                                  ItemsSource="{Binding Balances}"
                                  SelectedItem="{Binding BalanceSeleccionado}"
                                  Grid.Row="2"
                                  Grid.Column="1"
                                  Height="38"
                                  Background="#DDDDDD"
                                  BorderThickness="0"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="IdBalance"/>
                        </Grid>
                    </Grid>

                    <!-- DERECHA: AUTOMATIZACIÓN -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- CHECK -->
                        <CheckBox
                            Grid.Row="0"
                            Content="Asientos Automáticos"
                            Foreground="White"
                            VerticalAlignment="Center"
                            IsChecked="{Binding TieneAutomatizacion, Mode=TwoWay}"/>

                        <!-- TABLA -->
                        <Border Grid.Row="2"
                            Background="White"
                            BorderBrush="Black"
                            BorderThickness="1">
                            <DataGrid 
                                  ItemsSource="{Binding Automatizacion}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  RowHeight="26"
                                  FontSize="11"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cuenta" Binding="{Binding CuentaCodigo}" Width="*"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoMovimiento}" Width="60"/>
                                    <DataGridTextColumn Header="%" Binding="{Binding Porcentaje}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- BOTONES AUTOMATIZACIÓN -->
                        <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left">
                            <Button x:Name="btnAsientoMas"
                                Content="Asiento +"
                                Width="110"
                                Height="38"
                                Margin="0,0,10,0"
                                Background="#B88347"
                                Foreground="#00FF66"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding AsientoMasCommand}"/>

                            <Button x:Name="btnAsientoMenos"
                                Content="Asiento -"
                                Width="110"
                                Height="38"
                                Background="#B88347"
                                Foreground="Red"
                                FontWeight="Bold"
                                BorderThickness="0"
                                 Command="{Binding AsientoMenosCommand}"/>
                        </StackPanel>

                        <!-- GUARDAR AUTOMATIZACIÓN -->
                        <Button x:Name="btnGuardarAutomatizacion"
                            Grid.Row="6"
                            Content="Guardar Automatización"
                            Width="230"
                            Height="40"
                            HorizontalAlignment="Left"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Command="{Binding GuardarAutomatizacionCommand}"
                                />

                        <!-- LOGO/CAPIBARA -->
                        <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                            <Image Source="/Assets/capibara.png"
                               Width="90"/>
                            <TextBlock Text="KapiConta"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>