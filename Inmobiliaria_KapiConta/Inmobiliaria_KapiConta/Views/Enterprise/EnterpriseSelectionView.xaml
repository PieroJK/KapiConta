<UserControl x:Class="Inmobiliaria_KapiConta.Views.Enterprise.EnterpriseSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
        
        <Border Background="#5A3E2B"
        CornerRadius="0"
        Width="350"
        Padding="20">

            <!-- 🔥 GRID PROFESIONAL -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Título -->
                    <RowDefinition Height="*"/>
                    <!-- Lista -->
                    <RowDefinition Height="Auto"/>
                    <!-- Botones -->
                </Grid.RowDefinitions>

                <!-- 🟢 TÍTULO -->
                <TextBlock Text="Seleccione Empresas"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- 🔵 LISTA -->
                <Border Grid.Row="1"
                        Background="#D9D9D9"
                        CornerRadius="5"
                        BorderBrush="Black"
                        BorderThickness="2">

                    <ListBox ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBoxItem Content="CONTRATISTA AROTUMA E.I.R.L."/>
                        <ListBoxItem Content="INMOBILIARIA CONSTRUCTIVOS S.A.C."/>
                        <ListBoxItem Content="AROTUMA SERVIA MANUEL JONA"/>
                        <ListBoxItem Content="PONCE ALVA CARLO"/>
                        <ListBoxItem Content="CONECTA SOLUCIONES INMOBILIARIAS S.A.C."/>
                        <ListBoxItem Content="FAMILY HOUSE GRUPO INMOBILIARIO S.A.C."/>
                        <ListBoxItem Content="SABAC INVERSIONES E.I.R.L."/>
                        <ListBoxItem Content="MAGALLANES DENTALSTUDIO E.I.R.L."/>
                        <ListBoxItem Content="KF INVERSIONES GENERALES E.I.R.L."/>
                    </ListBox>

                </Border>

                <!-- 🟠 BOTONES -->
                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Content="REGISTRAR NUEVA EMPRESA"
                            Grid.Column="0"
                            Margin="5"
                            Height="40"
                            Background="#3A4CBF"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Cursor="Hand"/>

                    <Button Content="MODIFICAR EMPRESA"
                            Grid.Column="1"
                            Margin="5"
                            Height="40"
                            Background="#FF5A1F"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
