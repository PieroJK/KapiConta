<UserControl x:Class="Inmobiliaria_KapiConta.Views.Enterprise.SeleccionEmpresaPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#149191">
        <Border Width="500"
                Padding="30"
                CornerRadius="20"
                Background="#DDDDDD"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="SELECCIONAR EMPRESA"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Empresa"
                           FontSize="16"
                           Margin="0,0,0,10"/>

                <!-- 🔥 Binding real -->
                <ComboBox Height="35"
                          ItemsSource="{Binding Empresas}"
                          SelectedItem="{Binding EmpresaSeleccionada}"
                          DisplayMemberPath="Nombre"/>

                <Button Content="CONTINUAR"
                        Height="40"
                        Margin="0,25,0,0"
                        Background="#F05A28"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Command="{Binding ContinuarCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>