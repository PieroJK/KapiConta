<UserControl x:Class="Inmobiliaria_KapiConta.Views.Enterprise.SeleccionEmpresaPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#149191">
        <Button Content="←"
                Width="40"
                Height="40"
                FontSize="20"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="15"
                Cursor="Hand"
                Opacity="0.8"
                Command="{Binding VolverCommand}"/>
        
        <Border Width="400"
                Padding="30"
                CornerRadius="20"
                Background="#5A3E2B"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="SELECCIONAR EMPRESA"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"
                           Foreground="White"/>
                <DataGrid ItemsSource="{Binding Empresas}"
                          SelectedItem="{Binding EmpresaSeleccionada}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="None"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          Height="250"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          >

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Nombre}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 🔥 TABLA EN VEZ DE COMBO -->

                <!-- 🔥 BOTONES NUEVOS -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="76" Width="340">

                    <Button Content="Registrar Nueva Empresa"
                            Width="160"
                            Height="45"
                            Margin="0,20,10,0"
                            Background="#3498DB"
                            Foreground="White"
                            FontWeight="Bold" />

                    <Button Content="Modificar Empresa"
                            Width="171"
                            Height="44"
                            Margin="0,20,10,0"
                            Background="#F39C12"
                            Foreground="White"
                            FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>