<UserControl x:Class="Inmobiliaria_KapiConta.Views.Enterprise.ListEnterpriseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#2F4A5A">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔹 LISTADO IZQUIERDA -->
        <Border Background="#E0E0E0" CornerRadius="5">
            <ListBox ItemsSource="{Binding Items}"
                     DisplayMemberPath="Nombre"
                     SelectedItem="{Binding SelectedItem}"/>
        </Border>

        <!-- 🔹 PANEL DERECHO -->
        <StackPanel Grid.Column="2" Margin="20,0,0,0">

            <TextBlock Text="Listado Empresas"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,20"/>

            <!-- RUC -->
            <TextBox x:Name="txtRuc"
                     Text="{Binding SelectedItem.Ruc, UpdateSourceTrigger=PropertyChanged}"
                     Height="35"
                     Margin="0,5"
                     Background="#D9D9D9"/>

            <!-- Nombre -->
            <TextBox Text="{Binding SelectedItem.Nombre, UpdateSourceTrigger=PropertyChanged}"
                     Height="35"
                     Margin="0,5"
                     Background="#D9D9D9"/>

            <!-- Dirección -->
            <TextBox Text="{Binding SelectedItem.Direccion, UpdateSourceTrigger=PropertyChanged}"
                     Height="60"
                     Margin="0,5"
                     TextWrapping="Wrap"
                     Background="#D9D9D9"/>

            <!-- Estado -->
            <ComboBox SelectedItem="{Binding SelectedItem.Estado}"
                      Height="35"
                      Margin="0,10"
                      IsEnabled="False">
                <ComboBoxItem Content="Activo"/>
                <ComboBoxItem Content="Inactivo"/>
            </ComboBox>

            <!-- BOTONES -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">

                <Button Command="{Binding VolverCommand}"
                        Content="Volver"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Background="#C0392B"
                        Foreground="White"
                        FontWeight="Bold" />

                <Button Command="{Binding ModificarCommand}"
                        Content="Modificar"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Background="#F1C40F"
                        Foreground="Black"
                        FontWeight="Bold"/>

                <Button Command="{Binding EliminarCommand}"
                        Content="Eliminar"
                        Width="100"
                        Height="40"
                        Background="#922B21"
                        Foreground="White"
                        FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>